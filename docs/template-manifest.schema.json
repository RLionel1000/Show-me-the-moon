{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://lunar-core.dev/schema/template-manifest.schema.json",
  "title": "Show me the moon Template Manifest",
  "type": "object",
  "required": ["id", "name", "version", "coreApiVersion", "entry", "license", "compatibility"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9][a-z0-9-]{2,63}$"
    },
    "name": {
      "type": "string",
      "minLength": 3,
      "maxLength": 80
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "description": {
      "type": "string",
      "maxLength": 300
    },
    "license": {
      "type": "string",
      "minLength": 2
    },
    "author": {
      "type": "string"
    },
    "homepage": {
      "type": "string",
      "format": "uri"
    },
    "source": {
      "type": "string",
      "format": "uri"
    },
    "coreApiVersion": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$"
    },
    "compatibility": {
      "type": "object",
      "required": ["coreApi"],
      "properties": {
        "coreApi": {
          "type": "string",
          "description": "Semver range, e.g. ^0.1.0"
        }
      },
      "additionalProperties": false
    },
    "entry": {
      "type": "string",
      "pattern": "^src/.+\\.js$"
    },
    "capabilities": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "ui.panel",
          "overlay.landmarks",
          "overlay.lines",
          "storage.local",
          "network.http"
        ]
      },
      "uniqueItems": true
    },
    "attribution": {
      "type": "object",
      "required": ["upstreamName", "upstreamUrl"],
      "properties": {
        "upstreamName": { "type": "string" },
        "upstreamUrl": { "type": "string", "format": "uri" },
        "note": { "type": "string", "maxLength": 200 }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}
